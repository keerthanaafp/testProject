{
  "label": "mobile_app_keerthanaa",
  "views": {
    "add_job": {
      "ui": [
        {
          "text": "Add Job",
          "type": "text",
          "element_id": "job_card_title",
          "font_weight": "700"
        },
        {
          "type": "space_widget",
          "space": 16
        },
        {
          "data": [
            "Maintenance",
            "Installation",
            "Repair",
            "Inspection"
          ],
          "type": "input",
          "label": "Job Type",
          "element_id": "job_title_input",
          "input_type": "dropdown"
        },
        {
          "type": "space_widget",
          "space": 16
        },
        {
          "type": "input",
          "label": "Equipment Name",
          "element_id": "equipment_input",
          "input_type": "text"
        },
        {
          "type": "space_widget",
          "space": 16
        },
        {
          "type": "input",
          "label": "Description",
          "max_lines": 3,
          "element_id": "remarks_input",
          "input_type": "text"
        },
        {
          "type": "space_widget",
          "space": 24
        },
        {
          "text": "Submit",
          "type": "button",
          "onclick": {
            "1": {
              "type": "execute_query",
              "query": "INSERT INTO job_card_keerthanaa  (job_title, equipment, description, customer_id, status, created_at) VALUES ('{{input_data.job_title_input.[index]}}', '{{input_data.equipment_input.[index]}}', '{{input_data.remarks_input.[index]}}', '{{arguments.customer_id}}', 'Created', NOW()) ORDER BY id DESC"
            },
            "2": {
              "type": "navigation",
              "app_id": "7vw0X0F",
              "view_id": "detailed_customer_screen_keerthanaa",
              "arguments": {
                "customer_id": "{{arguments.customer_id}}"
              }
            }
          },
          "btn_type": "filled_button"
        }
      ],
      "data": {},
      "label": "Add Job",
      "margin": {
        "top": 16,
        "left": 16,
        "right": 16,
        "bottom": 16
      },
      "view_id": "add_job"
    },
    "job_complete": {
      "ui": [
        {
          "type": "input",
          "label": "Customer Signature",
          "width": 12,
          "height": 200,
          "element_id": "input_sig",
          "input_type": "signature"
        },
        {
          "type": "input",
          "label": "Remarks",
          "element_id": "remarks_input",
          "input_type": "text"
        },
        {
          "text": "Job Completed",
          "type": "text"
        },
        {
          "text": "Complete Job",
          "type": "button",
          "onclick": {
            "1": {
              "type": "execute_query",
              "query": "UPDATE job_card_keerthanaa SET status = 'Completed', completed_at = NOW() WHERE id = '{{arguments.job_id}}'"
            },
            "2": {
              "key": "job",
              "type": "update_data",
              "query": "SELECT * FROM job_card_keerthanaa WHERE id = '{{arguments.job_id}}' ORDER BY id DESC"
            },
            "3": {
              "type": "navigation",
              "app_id": "7vw0X0F",
              "view_id": "job_detailed_view",
              "arguments": {
                "job_id": "{{arguments.job_id}}"
              },
              "navigation_type": "view"
            }
          },
          "replace": true,
          "btn_type": "filled_button",
          "element_id": "complete_job_button"
        }
      ],
      "data": {
        "customers": "SELECT * FROM customer_form_keerthanaa WHERE id = '{{arguments.customer_id}}"
      },
      "margin": {
        "top": 16,
        "left": 16,
        "right": 16,
        "bottom": 16
      },
      "label": "Job Completed",
      "view_id": "job_complete"
    },
    "job_detailed_view": {
      "ui": [
        {
          "text": "Job Detail",
          "type": "text",
          "element_id": "job_detail_title"
        },
        {
          "type": "space_widget",
          "space": 16
        },
        {
          "ui": [
            {
              "text": "Equipment :",
              "type": "text",
              "element_id": "lbl_equipment"
            },
            {
              "type": "space_widget",
              "space": 10,
              "alignment": "horizontal"
            },
            {
              "text": "{{job.data.[0].equipment}}",
              "type": "text",
              "element_id": "txt_equipment"
            }
          ],
          "type": "row",
          "element_id": "row_equipment"
        },
        {
          "type": "space_widget",
          "space": 8,
          "element_id": "sp_1"
        },
        {
          "ui": [
            {
              "text": "Job Title :",
              "type": "text",
              "element_id": "lbl_job_title"
            },
            {
              "type": "space_widget",
              "space": 10,
              "alignment": "horizontal"
            },
            {
              "text": "{{job.data.[0].job_title}}",
              "type": "text",
              "font_size": 15,
              "element_id": "txt_job_title"
            }
          ],
          "type": "row",
          "element_id": "row_job_title"
        },
        {
          "type": "space_widget",
          "space": 8,
          "element_id": "sp_2"
        },
        {
          "ui": [
            {
              "text": "Description :",
              "type": "text",
              "element_id": "lbl_description"
            },
            {
              "type": "space_widget",
              "space": 10,
              "alignment": "horizontal"
            },
            {
              "text": "{{job.data.[0].description}}",
              "type": "text",
              "element_id": "txt_description"
            }
          ],
          "type": "row",
          "element_id": "row_description"
        },
        {
          "type": "space_widget",
          "space": 8,
          "element_id": "sp_3"
        },
        {
          "ui": [
            {
              "text": "Status :",
              "type": "text",
              "element_id": "lbl_status"
            },
            {
              "type": "space_widget",
              "space": 10,
              "alignment": "horizontal"
            },
            {
              "text": "{{job.data.[0].status}}",
              "type": "text",
              "element_id": "txt_status"
            }
          ],
          "type": "row",
          "element_id": "row_status"
        },
        {
          "type": "space_widget",
          "space": 24,
          "element_id": "sp_4"
        },
        {
          "text": "Job Completed",
          "type": "text",
          "color": "#008000",
          "element_id": "txt_job_completed",
          "visibility_condition": "'{{job.data.[0].status}}' ='Completed'"
        },
        {
          "type": "space_widget",
          "space": 24,
          "element_id": "sp_5"
        },
        {
          "text": "Start Job",
          "type": "button",
          "onclick": {
            "1": {
              "type": "execute_query",
              "query": "UPDATE job_card_keerthanaa SET status = 'In Progress', started_at = NOW() WHERE id = '{{arguments.job_id}}'"
            },
            "2": {
              "key": "job",
              "type": "update_data",
              "query": "SELECT * FROM job_card_keerthanaa WHERE id = '{{arguments.job_id}}' ORDER BY id DESC"
            }
          },
          "replace": true,
          "btn_type": "filled_button",
          "element_id": "btn_start_job",
          "visibility_condition": "'{{job.data.[0].status}}' ='Created'"
        },
        {
          "text": "Enter Evidence",
          "type": "button",
          "onclick": {
            "1": {
              "type": "execute_query",
              "query": "UPDATE job_card_keerthanaa SET status = 'Evidence Created' WHERE id = '{{arguments.job_id}}'"
            },
            "2": {
              "type": "navigation",
              "app_id": "7vw0X0F",
              "view_id": "enter_evidence_view",
              "arguments": {
                "job_id": "{{arguments.job_id}}"
              },
              "navigation_type": "view"
            }
          },
          "replace": true,
          "btn_type": "filled_button",
          "element_id": "enter_evidence",
          "visibility_condition": "'{{job.data.[0].status}}' ='In Progress'"
        },
        {
          "type": "space_widget",
          "space": 24,
          "element_id": "sp_6"
        },
        {
          "text": "Activity Log",
          "type": "text",
          "font_size": 14,
          "element_id": "txt_activity_log"
        },
        {
          "type": "space_widget",
          "space": 8,
          "element_id": "sp_7"
        },
        {
          "text": "Job created at : {{job.data.[0].created_at}}",
          "type": "text",
          "font_size": 12,
          "element_id": "txt_created_at"
        },
        {
          "type": "space_widget",
          "space": 4,
          "element_id": "sp_8"
        },
        {
          "text": "Job started at : {{job.data.[0].started_at}}",
          "type": "text",
          "font_size": 12,
          "element_id": "txt_started_at"
        },
        {
          "type": "space_widget",
          "space": 4,
          "element_id": "sp_9"
        },
        {
          "text": "Job Completed at : {{job.data.[0].completed_at}}",
          "type": "text",
          "font_size": 12,
          "element_id": "txt_completed_at"
        }
      ],
      "data": {
        "job": "SELECT * FROM job_card_keerthanaa WHERE id = '{{arguments.job_id}}'"
      },
      "label": "Job Detail",
      "margin": {
        "top": 16,
        "left": 16,
        "right": 16,
        "bottom": 16
      },
      "view_id": "job_detailed_view"
    },
    "customer_list_view": {
