    {
      "text": "Start Job",
      "type": "button",
      "width": 600,
      "onclick": {
        "1": {
          "type": "execute_query",
          "query": "UPDATE job_card_keerthanaa SET status = 'In Progress', start_job = '{<!getLocation().longitude!>, <!getLocation().latitude!>}', started_at = NOW() WHERE id = '{{arguments.job_id}}'"
        },
        "2": {
          "key": "job",
          "type": "update_data",
          "query": "SELECT * FROM job_card_keerthanaa WHERE id = '{{arguments.job_id}}'"
        }
      },
      "replace": true,
      "btn_type": "filled_button",
      "element_id": "btn_start_job",
      "visibility_condition": "'{{job.data.[0].status}}' ='Created'"
    },
    {
      "text": "Enter Evidence",
      "type": "button",
      "width": 600,
      "onclick": {
        "1": {
          "type": "navigation",
          "app_id": "7vw0X0F",
          "view_id": "enter_evidence_view",
          "arguments": {
            "job_id": "{{arguments.job_id}}"
          },
          "navigation_type": "view"
        }
      },
      "replace": true,
      "btn_type": "filled_button",
      "element_id": "enter_evidence",
      "visibility_condition": "'{{job.data.[0].status}}' ='In Progress'"
    },
