                  "border_bottom_width": 1
                }
              ],
              "data": "jobs_list.data",
              "type": "list",
              "search": true,
              "separator": true,
              "search_query": "SELECT j.id, j.job_title, j.equipment, j.status, j.description, j.created_at, c.first_name, c.last_name FROM job_card_keerthanaa j LEFT JOIN customer_form_keerthanaa c ON j.customer_id = c.id WHERE (COALESCE(j.job_title, '') ILIKE '%search_term%' OR COALESCE(j.equipment, '') ILIKE '%search_term%' OR COALESCE(j.status, '') ILIKE '%search_term%' OR COALESCE(c.first_name, '') ILIKE '%search_term%' OR COALESCE(c.last_name, '') ILIKE '%search_term%') ORDER BY j.id DESC",
              "header_background_color": "#F9FAFB"
            }
          ],
          "type": "container",
          "width": 12,
          "padding_top": 20,
          "border_color": "#E5E7EB",
          "border_width": 1,
          "padding_left": 20,
          "border_radius": 12
        }
      ],
      "type": "container",
      "width": 22,
      "element_id": "jobs_main",
      "padding_top": 32,
      "padding_left": 32,
      "padding_right": 32
    }
  ],
  "data": {
    "jobs_list": "SELECT j.id, j.job_title, j.equipment, j.status, j.description, j.created_at, c.first_name, c.last_name FROM job_card_keerthanaa j LEFT JOIN customer_form_keerthanaa c ON j.customer_id = c.id ORDER BY j.id DESC"
  },
  "label": "Jobs",
  "view_id": "jobs_list_view"
